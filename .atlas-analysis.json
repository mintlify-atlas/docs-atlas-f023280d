  "keyFeatures": [
    "Result<T, E> monad for explicit, type-safe error handling",
    "Maybe<T> monad as a safe alternative to null/undefined",
    "Try type for wrapping functions that throw exceptions",
    "AsyncResult for promise-based async error handling",
    "Structured error system with Zod validation, notes, and chaining",
    "Retry utilities with exponential, linear, and constant backoff strategies",
    "Sleep and timeout utilities for async workflows",
    "Pipe and flow composition helpers",
    "Zero runtime dependencies (Zod optional for error schemas)",
    "Full TypeScript 5.0+ support with perfect type inference"
  ],
  "publicApiSurface": [
    "ok(value) / err(error) — Result constructors",
    "isOk(result) / isErr(result) — Result type guards",
    "mapResult / flatMapResult / mapErr — Result transformations",
    "matchResult / tapResult — Result utilities",
    "some(value) / none() / fromNullable(value) — Maybe constructors",
    "isSome(maybe) / isNone(maybe) — Maybe type guards",
    "mapMaybe / flatMapMaybe — Maybe transformations",
    "attempt(fn) / attemptAsync(fn) — Try constructors",
    "okAsync / errAsync / fromPromise — AsyncResult constructors",
    "all / allSettled / race / traverse — AsyncResult combinators",
    "error(options) — Structured error factory",
    "exceptionGroup(errors) — Error grouping",
    "retryAsync(fn, options) — Retry with backoff",
    "sleep(ms) / withTimeout(promise, ms) — Timing utilities",
    "pipe / flow / pipeAsync / flowAsync — Composition helpers",
    "toResult / fromMaybe / toMaybeFromResult — Type conversions"
  ]
}
