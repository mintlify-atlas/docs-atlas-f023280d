  "projectName": "@deessejs/fp",
  "projectDescription": "Zero-dependency TypeScript library providing functional programming primitives — Result, Maybe, Try, and AsyncResult monads — for bulletproof, type-safe error handling.",
  "theme": "luma",
  "primaryColor": "#848484",
  "lightColor": "#0d0d0d",
  "darkColor": "#d3d3d4",
